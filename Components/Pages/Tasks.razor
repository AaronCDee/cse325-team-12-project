@page "/"
@page "/tasks"
@rendermode InteractiveServer
@attribute [Authorize]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<TaskTrackerDbContext> DbContextFactory
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>My Tasks</PageTitle>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">

    <!-- Added: Search input and button -->
    <div class="flex-grow-1 me-3 d-flex">
        <input type="text"
               class="form-control me-2 mb-3"
               placeholder="🔍 Search tasks by title or description..."
               @bind="searchTerm" />
        <button class="btn btn-outline-primary mb-3"
                @onclick="PerformSearch">
            Search
        </button>
    </div>

    <div>
        <h1 class="mb-1">My Tasks</h1>
        <p class="text-muted mb-0">Manage everything assigned to your account.</p>
    </div>
    <a class="btn btn-primary" href="/tasks/new">Create Task</a>
</div>

@if (isLoading)
{
    <p>Loading tasks...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h6 text-muted">Total</h2>
                    <p class="display-6 mb-0">@tasks.Count</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h6 text-muted">Pending</h2>
                    <p class="display-6 mb-0">@tasks.Count(task => !task.IsCompleted)</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h6 text-muted">Completed</h2>
                    <p class="display-6 mb-0">@tasks.Count(task => task.IsCompleted)</p>
                </div>
            </div>
        </div>
    </div>

    @if (!FilteredTasks.Any())
    {
        <div class="alert alert-light border">
            You have no tasks yet or no tasks match your search. Create your first one to get started.
        </div>
    }
    else
    {
        <div class="vstack gap-3">
            @foreach (var task in FilteredTasks)
            {
                <section class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex flex-wrap justify-content-between gap-3">
                            <div>
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <h2 class="h5 mb-0">@task.Title</h2>
                                    <span class="badge @(task.IsCompleted ? "text-bg-success" : "text-bg-warning")">
                                        @(task.IsCompleted ? "Completed" : "Pending")
                                    </span>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(task.Description))
                                {
                                    <p class="mb-2">@task.Description</p>
                                }

                                <p class="text-muted mb-0">
                                    Created @task.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                    @if (task.DueDateUtc.HasValue)
                                    {
                                        <span class="ms-3">Due @task.DueDateUtc.Value.ToLocalTime().ToString("MMM d, yyyy")</span>
                                    }
                                </p>
                            </div>

                            <div class="d-flex flex-wrap gap-2 align-self-start">
                                <button type="button"
                                        class="btn btn-outline-success"
                                        @onclick="() => ToggleCompletionAsync(task.Id)">
                                    @(task.IsCompleted ? "Mark Incomplete" : "Mark Complete")
                                </button>
                                <a class="btn btn-outline-primary" href="@($"/tasks/{task.Id}/edit")">Edit</a>
                                <button type="button"
                                        class="btn btn-outline-danger"
                                        @onclick="() => SetDeleteCandidate(task)">
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </section>
            }
        </div>
    }
}

@if (deleteCandidateId is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5 mb-0">Delete Task</h2>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="ClearDeleteCandidate"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">
                        Delete <strong>@deleteCandidateTitle</strong>? This action cannot be undone.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="ClearDeleteCandidate">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteAsync">
                        Delete task
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

@code {
    private readonly List<TaskItem> tasks = [];
    private bool isLoading = true;
    private int? deleteCandidateId;
    private string? deleteCandidateTitle;
    private string? errorMessage;
    private string? userId;

    // Added: Holds the search term entered by the user
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        await EnsureUserIdAsync();
        await LoadTasksAsync();
    }

    private async Task EnsureUserIdAsync()
    {
        if (!string.IsNullOrEmpty(userId))
        {
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = UserManager.GetUserId(authState.User);

        if (string.IsNullOrEmpty(userId))
        {
            NavigationManager.NavigateTo("/Identity/Account/Login", forceLoad: true);
        }
    }

    private async Task LoadTasksAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            await EnsureUserIdAsync();

            if (string.IsNullOrEmpty(userId))
            {
                return;
            }

            await using var dbContext = await DbContextFactory.CreateDbContextAsync();
            var results = await dbContext.Tasks
                .AsNoTracking()
                .Where(task => task.UserId == userId)
                .OrderBy(task => task.IsCompleted)
                .ThenBy(task => task.DueDateUtc ?? DateTime.MaxValue)
                .ThenByDescending(task => task.CreatedAtUtc)
                .ToListAsync();

            tasks.Clear();
            tasks.AddRange(results);
        }
        catch
        {
            errorMessage = "Tasks could not be loaded.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetDeleteCandidate(TaskItem task)
    {
        deleteCandidateId = task.Id;
        deleteCandidateTitle = task.Title;
    }

    private void ClearDeleteCandidate()
    {
        deleteCandidateId = null;
        deleteCandidateTitle = null;
    }

    private async Task ToggleCompletionAsync(int taskId)
    {
        await EnsureUserIdAsync();

        if (string.IsNullOrEmpty(userId))
        {
            return;
        }

        await using var dbContext = await DbContextFactory.CreateDbContextAsync();
        var task = await dbContext.Tasks.SingleOrDefaultAsync(item => item.Id == taskId && item.UserId == userId);

        if (task is null)
        {
            errorMessage = "That task could not be found.";
            return;
        }

        task.IsCompleted = !task.IsCompleted;
        await dbContext.SaveChangesAsync();
        await LoadTasksAsync();
    }

    private async Task ConfirmDeleteAsync()
    {
        if (deleteCandidateId is null)
        {
            return;
        }

        await EnsureUserIdAsync();

        if (string.IsNullOrEmpty(userId))
        {
            return;
        }

        await using var dbContext = await DbContextFactory.CreateDbContextAsync();
        var task = await dbContext.Tasks.SingleOrDefaultAsync(item => item.Id == deleteCandidateId && item.UserId == userId);

        if (task is null)
        {
            errorMessage = "That task could not be found.";
            ClearDeleteCandidate();
            return;
        }

        dbContext.Tasks.Remove(task);
        await dbContext.SaveChangesAsync();
        ClearDeleteCandidate();
        await LoadTasksAsync();
    }

    // Added: Filters tasks dynamically based on the search term
    private IEnumerable<TaskItem> FilteredTasks =>
        tasks.Where(t =>
            string.IsNullOrWhiteSpace(searchTerm) ||
            t.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (t.Description != null && t.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        );

    // Added: Called when the search button is clicked to refresh the filtered list
    private void PerformSearch()
    {
        StateHasChanged(); // Refreshes the UI
    }
}
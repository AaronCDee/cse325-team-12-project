@page "/profile/settings"
@rendermode InteractiveServer
@attribute [Authorize]

<PageTitle>Profile Settings</PageTitle>

<div class="mb-4">
    <h1 class="mb-1">Profile Settings</h1>
    <p class="text-muted mb-0">Review your account details and change them only when needed.</p>
</div>

@if (isLoading)
{
    <p>Loading profile...</p>
}
else
{
    <div class="row g-4">
        <div class="col-lg-6">
            <ProfileDetailsCard Model="profileModel"
                                IsEditing="isEditingProfile"
                                IsSaving="isSavingProfile"
                                Message="profileMessage"
                                MessageClass="ProfileMessageClass"
                                OnBeginEdit="BeginProfileEdit"
                                OnCancelEdit="CancelProfileEdit"
                                OnSave="RequestProfileSaveAsync" />
        </div>

        <div class="col-lg-6">
            <PasswordSettingsCard Model="passwordModel"
                                  HasPassword="hasPassword"
                                  IsEditing="isEditingPassword"
                                  IsSaving="isSavingPassword"
                                  Message="passwordMessage"
                                  MessageClass="PasswordMessageClass"
                                  OnBeginEdit="BeginPasswordEdit"
                                  OnCancelEdit="CancelPasswordEdit"
                                  OnSave="RequestPasswordSaveAsync" />
        </div>
    </div>
}

@if (pendingChange is not PendingChange.None)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5 mb-0">Confirm Change</h2>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="ClearPendingChange"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">@ConfirmMessage</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="ClearPendingChange">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmPendingChangeAsync">Confirm</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

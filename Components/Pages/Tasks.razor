@page "/"
@page "/tasks"
@rendermode InteractiveServer
@attribute [Authorize]

<PageTitle>My Tasks</PageTitle>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div>
        <h1 class="mb-1">My Tasks</h1>
        <p class="text-muted mb-0">Manage everything assigned to your account.</p>
    </div>
    <a class="btn btn-primary" href="/tasks/new">Create Task</a>
</div>

<div class="mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-lg-6">
            <div class="d-flex gap-2">
                <input type="text"
                       class="form-control"
                       placeholder="Search tasks by title or description..."
                       @bind="searchTerm" />
                <button class="btn btn-outline-primary"
                        @onclick="PerformSearch">
                    Search
                </button>
            </div>
        </div>
        <div class="col-lg-4">
            <label class="form-label" for="task-status-filter">Filter by status</label>
            <select id="task-status-filter"
                    class="form-select"
                    @bind="statusFilter">
                <option value="@TaskStatusFilter.All">All tasks</option>
                <option value="@TaskStatusFilter.Pending">Pending</option>
                <option value="@TaskStatusFilter.Completed">Completed</option>
            </select>
        </div>
    </div>
</div>

@if (isLoading)
{
    <p>Loading tasks...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h6 text-muted">Total</h2>
                    <p class="display-6 mb-0">@tasks.Count</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h6 text-muted">Pending</h2>
                    <p class="display-6 mb-0">@tasks.Count(task => !task.IsCompleted)</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h6 text-muted">Completed</h2>
                    <p class="display-6 mb-0">@tasks.Count(task => task.IsCompleted)</p>
                </div>
            </div>
        </div>
    </div>

    @if (!FilteredTasks.Any())
    {
        <div class="alert alert-light border">
            You have no tasks yet or no tasks match your current search and filter. Create your first one to get started.
        </div>
    }
    else
    {
        <div class="vstack gap-3">
            @foreach (var task in FilteredTasks)
            {
                <section class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex flex-wrap justify-content-between gap-3">
                            <div>
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <h2 class="h5 mb-0">@task.Title</h2>
                                    <span class="badge @(task.IsCompleted ? "text-bg-success" : "text-bg-warning")">
                                        @(task.IsCompleted ? "Completed" : "Pending")
                                    </span>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(task.Description))
                                {
                                    <p class="mb-2">@task.Description</p>
                                }

                                <p class="text-muted mb-0">
                                    Created @task.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                    @if (task.DueDateUtc.HasValue)
                                    {
                                        <span class="ms-3">Due @task.DueDateUtc.Value.ToLocalTime().ToString("MMM d, yyyy")</span>
                                    }
                                </p>
                            </div>

                            <div class="d-flex flex-wrap gap-2 align-self-start">
                                <button type="button"
                                        class="btn btn-outline-success"
                                        @onclick="() => ToggleCompletionAsync(task.Id)">
                                    @(task.IsCompleted ? "Mark Incomplete" : "Mark Complete")
                                </button>
                                <a class="btn btn-outline-primary" href="@($"/tasks/{task.Id}/edit")">Edit</a>
                                <button type="button"
                                        class="btn btn-outline-danger"
                                        @onclick="() => SetDeleteCandidate(task)">
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </section>
            }
        </div>
    }
}

<DeleteTaskModal IsVisible="deleteCandidateId is not null"
                 Title="deleteCandidateTitle"
                 OnCancel="ClearDeleteCandidate"
                 OnConfirm="ConfirmDeleteAsync" />

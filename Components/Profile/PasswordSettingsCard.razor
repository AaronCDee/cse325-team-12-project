@namespace TaskTracker.Components.Profile

<div class="card shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
                <h2 class="h5 mb-1">Password</h2>
                <p class="text-muted mb-0">Keep your account secure with a strong password.</p>
            </div>
            @if (!IsEditing)
            {
                <button type="button" class="btn btn-outline-primary" @onclick="OnBeginEdit">
                    Edit
                </button>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="alert @MessageClass">@Message</div>
        }

        @if (!IsEditing)
        {
            <dl class="row mb-0">
                <dt class="col-sm-4">Existing Password</dt>
                <dd class="col-sm-8">@(HasPassword ? "********" : "No password set")</dd>
            </dl>
        }
        else
        {
            <EditForm Model="Model" OnValidSubmit="HandleSaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="alert alert-danger" />

                <div class="mb-3">
                    <label class="form-label" for="current-password">Current Password</label>
                    <InputText id="current-password" type="password" class="form-control" @bind-Value="Model.CurrentPassword" />
                    <ValidationMessage class="text-danger" For="() => Model.CurrentPassword" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="new-password">New Password</label>
                    <InputText id="new-password" type="password" class="form-control" @bind-Value="Model.NewPassword" />
                    <ValidationMessage class="text-danger" For="() => Model.NewPassword" />
                </div>

                <div class="mb-4">
                    <label class="form-label" for="confirm-password">Confirm New Password</label>
                    <InputText id="confirm-password" type="password" class="form-control" @bind-Value="Model.ConfirmPassword" />
                    <ValidationMessage class="text-danger" For="() => Model.ConfirmPassword" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@IsSaving">Change Password</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="OnCancelEdit">Cancel</button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ChangePasswordModel Model { get; set; } = default!;
    [Parameter] public bool HasPassword { get; set; }
    [Parameter] public bool IsEditing { get; set; }
    [Parameter] public bool IsSaving { get; set; }
    [Parameter] public string? Message { get; set; }
    [Parameter] public string MessageClass { get; set; } = "alert-success";
    [Parameter] public EventCallback OnBeginEdit { get; set; }
    [Parameter] public EventCallback OnCancelEdit { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }

    private Task HandleSaveAsync() => OnSave.InvokeAsync();
}
